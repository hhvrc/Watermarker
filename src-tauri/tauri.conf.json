{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "watermarker",
  "version": "1.1.1",
  "identifier": "com.watermarker.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "watermarker",
        "width": 1320,
        "height": 860,
        "minWidth": 600,
        "minHeight": 850,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/hhvrc/Watermarker/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyOTU0RTlFQ0M0RDA0RQpSV1JPME1UczZWUXBCR1BYN29BamdqNGRnWnNYOWV3bE9CdmVMMzRkYU9TSTBsMHpoVUpxMS9BQQo="
    }
  }
}
